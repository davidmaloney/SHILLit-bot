# === BOT IDENTITY ===

# Your bot's token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# The ID of your shillit Telegram group. Get it by adding the bot to the
# group, sending a message, then visiting:
# https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
# Look for "chat":{"id": -100...} — copy that whole number including the minus sign.
GROUP_CHAT_ID=

# Your own Telegram user ID. Get it from @userinfobot. This makes you the
# Founder — full access to everything, always, no matter what.
FOUNDER_USER_ID=

# === PULSES ===
# Pulses are the random "I'm in" prompts that pop up in the group and
# build people's Conviction score.

# Shortest possible gap between Pulses, in minutes
PULSE_MIN_INTERVAL_MINUTES=240

# A Pulse is guaranteed to fire by this point even on bad luck, in minutes
PULSE_MAX_INTERVAL_MINUTES=1440

# Chance (0 to 1) a Pulse fires once the minimum gap has passed
PULSE_FIRE_CHANCE=0.4

# === ROLES & TITLES ===
# Title ladder: Lurker → Shill Initiate → Bag Holder → Diamond Hand →
# Signal Reader → Conviction Holder → Council of Shillers
# Diamond Hand+ unlocks bot moderator rights, Conviction Holder+ unlocks
# bot admin rights, Council of Shillers unlocks the hidden image command.

# Days of inactivity before a Diamond Hand+ member loses their title and
# role and has to climb back up
ROLE_DECAY_DAYS=30

# === COMMENT RAIDS ===
# Someone posts an X link with their own comment underneath. It becomes
# a vote card. Enough votes flips it into a live raid box with the link.

# Minimum title needed to post a raid card. Founder always bypasses this.
# Use "Lurker" to let anyone post, or raise it (e.g. "Diamond Hand") once
# the group has grown and you want posting earned, not automatic.
RAID_REQUIRED_TITLE=Diamond Hand

# Votes needed before a card flips into a live raid
RAID_VOTE_THRESHOLD=5

# Legacy setting, kept for compatibility, no longer shown on the raid box
RAID_DEFAULT_TARGET=10

# Minutes a vote card stays open before it quietly expires if it never
# gets enough votes
CARD_EXPIRY_MINUTES=180

# How many times a raid box can be reposted before it stops competing for
# repost slots — keeps old raids from looping forever
RAID_REPOST_LIMIT=3

# After this many new chat messages, the top voting card and top raid box
# get reposted so they don't get buried in a busy chat
REPOST_EVERY_N_MESSAGES=15

# === STATUS SPOTLIGHT ===
# Occasionally the bot randomly calls out an active member's status in
# the group, just to keep things alive.

SPOTLIGHT_MIN_INTERVAL_MINUTES=360
SPOTLIGHT_MAX_INTERVAL_MINUTES=1440
SPOTLIGHT_FIRE_CHANCE=0.3

# === KEYWORD REPLIES ===
# Someone types one of these words on its own and the bot replies with
# the value below. Case doesn't matter. Won't trigger on messages that
# contain a link, so raid cards never get mixed up with these.
# (The "info" keyword's reply is long, so it lives in the code itself,
# not here — edit keywordHandler.js directly to change it.)

KEYWORD_X_REPLY=https://x.com/shillitfun?s=11
KEYWORD_WEB_REPLY=SHILLit.fun
KEYWORD_SITE_REPLY=Not up yet
KEYWORD_CA_REPLY=Not added yet
KEYWORD_TG_REPLY=https://t.me/shillitchat
